# Example environment variables for Zyphoric
# Secrets (required)
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the model (must be one of allowed models)
GROQ_MODEL=llama-3.1-8b-instant

# Optional: change the API base (useful for testing/mocks)
GROQ_API_BASE=https://api.groq.com/openai/v1

# Timeouts and quotas (milliseconds)
AI_TIMEOUT_MS=15000
VITE_AI_TIMEOUT_MS=15000
QUOTA_WINDOW_MS=3600000
AI_QUOTA_MAX=100
QUOTA_CLEANUP_INTERVAL_MS=900000

# Rate limiter (ms and max requests per window)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Vite/client settings
VITE_AI_PROXY_URL=/api/ai

# Server
PORT=3000
NODE_ENV=development

# Base site URL for generated sitemap/static SEO files
SITE_URL=https://zyphoric.netlify.app

# Base site URL exposed to the browser for canonical/social metadata
VITE_SITE_URL=https://zyphoric.netlify.app
